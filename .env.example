# ============================================================
# 한국 경제 & 서울 부동산 대시보드 — 환경 변수
# ============================================================
# 복사 후 .env로 저장: cp .env.example .env
# 실제 값으로 교체 필요
# ============================================================

# ---- ECOS API ----
# 한국은행 ECOS 오픈 API 인증키
# 발급: https://ecos.bok.or.kr/api/#/DevGuide/TokenKey
ECOS_API_KEY=your_ecos_api_key_here

# ---- Gemini API ----
# Google Gemini API 키
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---- PostgreSQL DB (서울 부동산 데이터) ----
DB_HOST=leeghhome.iptime.org
DB_PORT=5432
DB_NAME=aptprice_data
DB_USER=postgres
DB_PASSWORD=your_db_password_here
